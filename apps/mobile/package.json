{
  "name": "@foodtrucks/mobile",
  "private": true,
  "version": "0.1.0",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "dev": "expo start",
    "build": "expo export --platform web --output-dir dist",
    "lint": "eslint \"**/*.{js,cjs,mjs,ts,tsx}\" --max-warnings=0 --no-error-on-unmatched-pattern",
    "typecheck": "tsc -p tsconfig.json",
    "test": "tsc -p tsconfig.test.json && node .codex-test/auth-api.test.js",
    "clean": "node -e \"require('fs').rmSync('.expo', { recursive: true, force: true }); require('fs').rmSync('dist', { recursive: true, force: true }); console.log('mobile clean ok')\""
  },
  "dependencies": {
    "@clerk/clerk-expo": "^2.19.31",
    "@tanstack/react-query": "5.95.2",
    "expo": "~52.0.49",
    "expo-application": "~6.0.2",
    "expo-auth-session": "6.0.3",
    "expo-constants": "~17.0.8",
    "expo-crypto": "~14.0.2",
    "expo-linking": "~7.0.5",
    "expo-router": "~4.0.22",
    "expo-secure-store": "14.0.1",
    "expo-status-bar": "~2.0.1",
    "expo-web-browser": "~14.0.2",
    "nativewind": "4.1.23",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-hook-form": "7.72.0",
    "react-native": "0.76.9",
    "react-native-css-interop": "0.1.22",
    "react-native-reanimated": "~3.16.7",
    "react-native-safe-area-context": "4.12.0",
    "react-native-screens": "~4.4.0",
    "react-native-web": "~0.19.13",
    "zod": "4.3.6",
    "zustand": "5.0.12"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@types/react": "~18.3.12",
    "tailwindcss": "3.4.17",
    "typescript": "^5.3.3"
  }
}
