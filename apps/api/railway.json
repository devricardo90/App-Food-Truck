{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "RAILPACK",
    "buildCommand": "pnpm install --frozen-lockfile && pnpm --filter @foodtrucks/api prisma:generate && pnpm --filter @foodtrucks/api build",
    "watchPatterns": [
      "/apps/api/**",
      "/packages/**",
      "/package.json",
      "/pnpm-lock.yaml",
      "/pnpm-workspace.yaml",
      "/turbo.json",
      "/tsconfig.base.json"
    ]
  },
  "deploy": {
    "preDeployCommand": "pnpm --filter @foodtrucks/api prisma:migrate:deploy",
    "startCommand": "pnpm --filter @foodtrucks/api start",
    "healthcheckPath": "/docs",
    "healthcheckTimeout": 300,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}
